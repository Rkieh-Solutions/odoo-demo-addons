<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Root menu — makes Pharmacy appear as a top-level App on the home screen -->
    <menuitem id="menu_pharmacy_root"
              name="Pharmacy"
              sequence="50"
              web_icon="pharmacy_management,static/description/icon.png"/>

    <!-- Products sub-menu -->
    <menuitem id="menu_pharmacy_products"
              name="Products"
              parent="menu_pharmacy_root"
              action="product.product_template_action_all"
              sequence="10"/>

    <!-- Also keep it accessible inside Inventory -->
    <menuitem id="menu_pharmacy_inventory"
              name="Pharmacy"
              parent="stock.menu_stock_root"
              sequence="100"/>

    <menuitem id="menu_pharmacy_products_inv"
              name="Products"
              parent="menu_pharmacy_inventory"
              action="product.product_template_action_all"
              sequence="10"/>

    <!-- Configuration Section (in standard Inventory / Configuration) -->
    <!-- NOTE: menu_pharmacy_config removed - it had no action and no child items -->

</odoo>
