<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Map Wizard View -->
    <record id="view_picking_route_map_wizard_form" model="ir.ui.view">
        <field name="name">picking.route.map.wizard.form</field>
        <field name="model">picking.route.map.wizard</field>
        <field name="arch" type="xml">
            <form string="Picking Route Map">
                <sheet>
                    <div class="oe_title mb-4">
                        <h1>Route Map for <field name="picking_id" readonly="1" class="oe_inline"/></h1>
                        <p class="text-muted">Follow these steps in order for the most efficient picking path.</p>
                    </div>
                    
                    <field name="line_ids">
                        <list create="0" edit="0" delete="0" decoration-success="is_picked" default_order="step">
                            <field name="step" string="Step No." widget="badge"/>
                            <field name="location_code" string="Walk to Bin"/>
                            <field name="product_id" string="Pick Product"/>
                            <field name="qty" string="Qty to Pick"/>
                            <field name="is_picked" string="Picked?" widget="boolean_toggle" readonly="1"/>
                        </list>
                    </field>
                </sheet>
                <footer>
                    <button name="action_close" string="Close Map"
                            type="object" class="btn-primary"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action for the Wizard -->
    <record id="action_picking_route_map_wizard" model="ir.actions.act_window">
        <field name="name">Route Map</field>
        <field name="res_model">picking.route.map.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Inherit Picking to Add Smart Button/Action -->
    <record id="view_picking_form_route_map_inherit" model="ir.ui.view">
        <field name="name">stock.picking.form.route.map.inherit</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="warehouse_access_control.view_picking_warehouse_form"/>
        <field name="arch" type="xml">
            <!-- Add a button in header directly -->
            <xpath expr="//header" position="inside">
                <button name="%(action_picking_route_map_wizard)d"
                        string="🗺️ Map Route"
                        type="action"
                        class="btn-info"
                        groups="warehouse_access_control.group_picker,warehouse_access_control.group_warehouse_supervisor"
                        invisible="custom_status not in ('picking_in_progress', 'released')"/>
            </xpath>
        </field>
    </record>
</odoo>
