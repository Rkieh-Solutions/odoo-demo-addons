<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sale Order Form Inheritance -->
    <record id="view_order_form_tier_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.tier.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sort_lines_by_tier" 
                        string="⚖️ Sort by Stacking Tier" 
                        type="object" 
                        class="btn-secondary"
                        invisible="state not in ['draft', 'sent']"/>
            </xpath>
            <xpath expr="//field[@name='order_line']//field[@name='product_id']" position="after">
                <field name="cargo_stacking_type" optional="show"/>
                <field name="cargo_tier" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Purchase Order Form Inheritance -->
    <record id="view_purchase_order_form_tier_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.tier.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_sort_lines_by_tier" 
                        string="⚖️ Sort by Stacking Tier" 
                        type="object" 
                        class="btn-secondary"
                        invisible="state not in ['draft', 'sent', 'to_approve']"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/list//field[@name='product_id']" position="after">
                <field name="cargo_stacking_type" optional="show"/>
                <field name="cargo_tier" optional="show"/>
            </xpath>
        </field>
    </record>
</odoo>
