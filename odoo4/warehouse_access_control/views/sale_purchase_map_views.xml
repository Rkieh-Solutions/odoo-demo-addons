<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Map Button to Sales Order -->
    <record id="view_sale_order_map_inherit" model="ir.ui.view">
        <field name="name">sale.order.form.map.inherit</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(warehouse_access_control.action_picking_route_map_wizard)d"
                        string="🗺️ Map &amp; Cargo Sequence"
                        type="action"
                        class="btn-info"
                        invisible="state not in ['sale', 'done']"/>
            </xpath>
        </field>
    </record>

    <!-- Add Map Button to Purchase Order -->
    <record id="view_purchase_order_map_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.map.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="%(warehouse_access_control.action_picking_route_map_wizard)d"
                        string="🗺️ Map &amp; Stacking Sequence"
                        type="action"
                        class="btn-info"
                        invisible="state not in ['purchase', 'done']"/>
            </xpath>
        </field>
    </record>
</odoo>
