<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ══════════════════════════════════════════════════════════
             INVENTORY ENHANCEMENTS
             - Margin & Margin % columns in product list
             - On-Order Quantity visible
             - Main Category / Sub-Category
             - Larger product image
        ══════════════════════════════════════════════════════════════ -->

        <!-- ── Product Template LIST — add margin + category columns ── -->
        <record id="view_product_template_warehouse_list" model="ir.ui.view">
            <field name="name">product.template.warehouse.list</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_tree_view"/>
            <field name="arch" type="xml">

                <!-- Add margin columns after price -->
                <xpath expr="//field[@name='list_price']" position="after">
                    <field name="standard_price" string="Cost"
                           optional="show"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_finance_viewer,warehouse_access_control.group_inventory_viewer"/>
                    <field name="margin" string="Margin"
                           optional="show"
                           decoration-danger="margin &lt; 0"
                           decoration-warning="margin == 0"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_finance_viewer,warehouse_access_control.group_inventory_viewer"/>
                    <field name="margin_pct" string="Margin %"
                           optional="show"
                           decoration-danger="margin_pct &lt; 0"
                           decoration-warning="margin_pct &lt; 10"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_finance_viewer,warehouse_access_control.group_inventory_viewer"/>
                </xpath>

                <!-- Add category columns -->
                <xpath expr="//field[@name='categ_id']" position="after">
                    <field name="main_categ_id" string="Main Category" optional="show"/>
                    <field name="sub_categ_id" string="Sub-Category" optional="show"/>
                </xpath>

            </field>
        </record>

        <!-- ── Product Template FORM — larger image + on-order + categories ── -->
        <record id="view_product_template_warehouse_form" model="ir.ui.view">
            <field name="name">product.template.warehouse.form</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">

                <!-- Larger image -->
                <xpath expr="//field[@name='image_1920']" position="replace">
                    <field name="image_1920" widget="image"
                           class="oe_avatar"
                           style="max-width:256px; max-height:256px;"
                           options="{'zoom': true, 'preview_image': 'image_128'}"/>
                </xpath>

                <!-- Add margin fields to Sales tab -->
                <xpath expr="//field[@name='list_price']" position="after">
                    <field name="margin" string="Margin" readonly="1"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_finance_viewer"/>
                    <field name="margin_pct" string="Margin %" readonly="1"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_finance_viewer"/>
                </xpath>

                <!-- Add on-order quantity near stock info -->
                <xpath expr="//field[@name='type']" position="after">
                    <field name="incoming_qty" string="On Order (Incoming)" readonly="1"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_inventory_viewer,warehouse_access_control.group_warehouse_supervisor,warehouse_access_control.group_purchasing_user"/>
                    <field name="cargo_stacking_priority" string="Cargo Packing Logic"
                           groups="warehouse_access_control.group_inventory_editor,warehouse_access_control.group_warehouse_supervisor"/>
                </xpath>

                <!-- Add Main / Sub category fields -->
                <xpath expr="//field[@name='categ_id']" position="after">
                    <field name="main_categ_id" string="Main Category" readonly="1"/>
                    <field name="sub_categ_id" string="Sub-Category"/>
                </xpath>

            </field>
        </record>

        <!-- ── Stock Quant (Current Stock) LIST — add margin ── -->
        <record id="view_stock_quant_warehouse_list" model="ir.ui.view">
            <field name="name">stock.quant.warehouse.list</field>
            <field name="model">stock.quant</field>
            <field name="inherit_id" ref="stock.view_stock_quant_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='quantity']" position="after">
                    <field name="reserved_quantity" string="Reserved" optional="show"/>
                </xpath>
            </field>
        </record>

        <!-- ── Product Template ACTION for Inventory roles ── -->
        <record id="action_inventory_products" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="res_model">product.template</field>
            <field name="view_mode">list,form,kanban</field>
            <field name="context">{'search_default_filter_to_purchase': 0}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No products found. Create your first product.
                </p>
            </field>
        </record>

    </data>
</odoo>
