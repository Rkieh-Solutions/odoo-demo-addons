<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_quality_check" model="ir.actions.report">
        <field name="name">Quality Inspection Certificate</field>
        <field name="model">quality.check</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">warehouse_access_control.report_quality_check_document</field>
        <field name="report_file">warehouse_access_control.report_quality_check_document</field>
        <field name="print_report_name">'Quality_Inspection_%s' % (object.name)</field>
        <field name="binding_model_id" ref="quality_control.model_quality_check"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_quality_check_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page">
                        <div class="row align-items-center mb-4">
                            <div class="col-8">
                                <h2>Quality Inspection Certificate</h2>
                                <h4 class="text-muted"><span t-field="doc.name"/></h4>
                            </div>
                            <div class="col-4 text-right">
                                <t t-if="doc.quality_state == 'pass'">
                                    <h2 style="color: #28a745; border: 3px solid #28a745; padding: 10px; display: inline-block;">PASSED</h2>
                                </t>
                                <t t-elif="doc.quality_state == 'fail'">
                                    <h2 style="color: #dc3545; border: 3px solid #dc3545; padding: 10px; display: inline-block;">FAILED</h2>
                                </t>
                                <t t-else="">
                                    <h2 style="color: #6c757d; border: 3px solid #6c757d; padding: 10px; display: inline-block;">PENDING</h2>
                                </t>
                            </div>
                        </div>

                        <div class="row mt-4 mb-4">
                            <div class="col-6">
                                <strong>Product:</strong> <span t-field="doc.product_id.display_name"/><br/>
                                <strong>Lot/Serial Number:</strong> <span t-field="doc.lot_id.name"/><br/>
                                <strong>Control Point:</strong> <span t-field="doc.point_id.name"/><br/>
                            </div>
                            <div class="col-6">
                                <strong>Date:</strong> <span t-field="doc.control_date"/><br/>
                                <strong>Inspector:</strong> <span t-field="doc.user_id.name"/><br/>
                                <strong>Transfer:</strong> <span t-field="doc.picking_id.name"/><br/>
                            </div>
                        </div>

                        <t t-if="doc.note">
                            <div class="row mt-4">
                                <div class="col-12">
                                    <h4>Inspection Notes / Instructions</h4>
                                    <div style="border: 1px solid #ddd; padding: 15px; border-radius: 5px;" t-raw="doc.note"/>
                                </div>
                            </div>
                        </t>

                        <div class="row mt-5">
                            <div class="col-6 text-center">
                                <hr style="border-top: 1px solid black; width: 80%; margin-top: 50px;"/>
                                <strong>Inspector Signature</strong>
                            </div>
                            <div class="col-6 text-center">
                                <hr style="border-top: 1px solid black; width: 80%; margin-top: 50px;"/>
                                <strong>Manager Approval</strong>
                            </div>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
