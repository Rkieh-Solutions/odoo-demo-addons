<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view_inherit_wood" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.wood</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_create_cutting_plan" string="Cutting Plan" type="object" class="btn-info" invisible="state == 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>
