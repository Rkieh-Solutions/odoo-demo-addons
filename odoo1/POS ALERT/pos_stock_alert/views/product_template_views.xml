<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_pos_stock_alert" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pos.stock.alert</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='inventory']//group[@name='operations']" position="inside">
                 <field name="x_qty_to_warn"/>
            </xpath>
        </field>
    </record>
</odoo>
