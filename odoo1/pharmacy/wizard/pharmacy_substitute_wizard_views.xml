<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_pharmacy_substitute_form" model="ir.ui.view">
        <field name="name">pharmacy.substitute.form</field>
        <field name="model">pharmacy.substitute</field>
        <field name="arch" type="xml">
            <form string="Find Substitutes">
                <group>
                    <group>
                        <field name="product_id"/>
                        <field name="match_mode"/>
                    </group>
                    <group>
                        <field name="in_stock_only"/>
                        <field name="limit"/>
                    </group>
                </group>
                <notebook>
                    <page string="Substitutes">
                        <field name="line_ids" readonly="1">
                            <list decoration-success="qty_available > 0" decoration-danger="qty_available == 0">
                                <field name="product_id"/>
                                <field name="composition_text"/>
                                <field name="qty_available"/>
                                <button name="action_replace" string="Replace Original" type="object" icon="fa-exchange"/>
                                <button name="action_add_new" string="Add to Order" type="object" icon="fa-plus"/>
                            </list>
                        </field>
                    </page>
                </notebook>
                <footer>
                    <button string="Close" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pharmacy_substitute_wizard" model="ir.actions.act_window">
        <field name="name">Find Substitutes</field>
        <field name="res_model">pharmacy.substitute</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
