<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.SelectLotPopup" t-inherit="point_of_sale.SelectLotPopup" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('popup')]" position="attributes">
            <attribute name="style" add="min-width: 550px;" separator=";"/>
        </xpath>
        <xpath expr="//span[hasclass('form-control')]" position="replace">
            <div class="form-control d-flex justify-content-between align-items-center">
                <span t-esc="v.text"/>
                <span t-if="v.expiration_date" class="badge rounded-pill bg-info text-dark">
                    Exp: <t t-esc="v.expiration_date.split(' ')[0]"/>
                </span>
            </div>
        </xpath>
    </t>
</templates>
