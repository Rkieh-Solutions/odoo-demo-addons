<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.CreateChildProductPopup">
        <Dialog title="props.title or '📦 Open Box: Create Child Product'" size="'md'" contentClass="'create-child-product-popup-dialog'">
            <div class="create-child-product-popup create-child-product-popup-box d-flex flex-column gap-3 mt-2">



                <!-- Name input -->
                <div class="form-group">
                    <label class="fw-bold mb-1">Child Product Name:</label>
                    <input type="text"
                           class="form-control form-control-lg border-primary shadow-sm"
                           placeholder="e.g. Paracetamol Tablet"
                           t-model="state.productName"
                           t-ref="name-input"
                           t-on-keydown="(ev) => ev.key === 'Enter' and onCreate()"/>
                </div>

                <!-- Quantity per Box input -->
                <div class="form-group">
                    <label class="fw-bold mb-1">Quantity in Box:</label>
                    <input type="number"
                           class="form-control form-control-lg border-primary shadow-sm"
                           placeholder="e.g. 10"
                           step="any"
                           inputmode="decimal"
                           t-model="state.envelopesPerBox"
                           t-on-keydown="(ev) => ev.key === 'Enter' and onCreate()"/>
                </div>

                <!-- Envelope sales price input -->
                <div class="form-group">
                    <label class="fw-bold mb-1">Envelope Sales Price:</label>
                    <input type="number"
                           class="form-control form-control-lg border-primary shadow-sm"
                           placeholder="Leave empty for auto-calc"
                           step="any"
                           inputmode="decimal"
                           t-model="state.envelopePrice"
                           t-on-keydown="(ev) => ev.key === 'Enter' and onCreate()"/>
                </div>

                <!-- Tracking selection -->
                <div class="form-group">
                    <label class="fw-bold mb-1">Inventory Tracking:</label>
                    <select class="form-select form-select-lg border-primary shadow-sm"
                            t-model="state.tracking">
                        <option value="none">By Quantity (No Lots)</option>
                        <option value="lot">By Lots</option>
                        <option value="serial">By Unique Serial Number</option>
                    </select>
                </div>

                <p class="text-muted small mt-1">New product will be created, linked to this box, and stock will be adjusted.</p>
            </div>
            <t t-slot="footer">
                <button class="btn btn-outline-secondary px-4" t-on-click="props.close">Cancel</button>
                <button class="btn btn-primary px-5 fw-bold" t-on-click="onCreate" t-att-disabled="!state.productName.trim()">
                    <i class="fa fa-plus me-1"/> Create
                </button>
            </t>
        </Dialog>
    </t>
</templates>
