<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.CreateChildProductPopup">
        <Dialog title="props.title or 'Create Child Product'" footer="false" size="'md'">
            <div class="create-child-product-popup d-flex flex-column gap-4 p-2">
                <div t-if="props.body" class="alert alert-warning shadow-sm border-0 d-flex align-items-center mb-0">
                    <i class="fa fa-info-circle me-3 fs-4 text-warning"/>
                    <span t-esc="props.body"/>
                </div>

                <div class="form-group">
                    <label for="child_product_name" class="form-label fw-bold mb-2">Child Product Name</label>
                    <div class="input-group shadow-sm">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fa fa-tag text-primary"/>
                        </span>
                        <input type="text" 
                               id="child_product_name"
                               class="form-control border-start-0 ps-0" 
                               placeholder="Enter child product name (e.g., Envelope, Piece...)" 
                               t-model="state.productName"
                               t-ref="name-input"
                               t-on-keydown="(ev) => ev.key === 'Enter' and onCreate()"/>
                    </div>
                    <div class="form-text mt-2">
                        This product will be created and linked as the child for packaging conversion.
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-2 pt-3 border-top mt-2">
                    <button class="btn btn-outline-secondary px-4 shadow-sm" t-on-click="props.close">Cancel</button>
                    <button class="btn btn-primary px-4 shadow-sm" 
                            t-on-click="onCreate"
                            t-att-disabled="!state.productName.trim()">
                        <i class="fa fa-plus-circle me-1"/> Create
                    </button>
                </div>
            </div>
        </Dialog>
    </t>
</templates>
