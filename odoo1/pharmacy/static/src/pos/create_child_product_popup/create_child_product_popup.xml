<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.CreateChildProductPopup">
        <Dialog title="props.title or '📦 Open Box: Create Child Product'" size="'md'" contentClass="'create-child-product-popup-dialog'">
            <div class="create-child-product-popup create-child-product-popup-box d-flex flex-column gap-3 mt-4">
                <div class="alert alert-info border-0 bg-transparent p-0 mb-0">
                    <p class="mb-2">This product has no child linked in <strong>Pharmacy Management</strong>.</p>
                    <p class="small text-muted mb-0">Enter a name to create and link it automatically as the "Envelope/Child Product".</p>
                </div>
                <div class="form-group">
                    <label class="fw-bold mb-1">New Child Name:</label>
                    <input type="text" 
                           class="form-control form-control-lg border-primary shadow-sm" 
                           placeholder="e.g. Tablets"
                           t-model="state.productName" 
                           t-ref="name-input" 
                           t-on-keydown="(ev) => ev.key === 'Enter' and onCreate()"/>
                </div>
            </div>
            <t t-slot="footer">
                <button class="btn btn-outline-secondary px-4" t-on-click="props.close">Cancel</button>
                <button class="btn btn-primary px-5 fw-bold" t-on-click="onCreate" t-att-disabled="!state.productName.trim()">
                    Create
                </button>
            </t>
        </Dialog>
    </t>
</templates>
