<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.SubstitutionPopup">
        <Dialog title="props.title or 'Find Substitutes'" size="'md'">
            <div class="substitution-popup d-flex flex-column gap-3 mt-3" style="max-height: 70vh; min-height: 400px;">
                <div class="search-box">
                    <input type="text" class="form-control" placeholder="Search substitutes..." t-model="state.searchTerm" t-ref="search-input"/>
                </div>
                <div class="substitute-list overflow-auto flex-grow-1">
                    <table class="table table-hover">
                        <thead class="sticky-top bg-white">
                            <tr>
                                <th>Product</th>
                                <th>Ingredients</th>
                                <th>Stock</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="filteredSubstitutes" t-as="sub" t-key="sub.id">
                                <tr class="align-middle">
                                    <td class="fw-bold"><t t-esc="sub.display_name"/></td>
                                    <td class="text-muted small"><t t-esc="sub.composition_text"/></td>
                                    <td>
                                        <span t-attf-class="badge #{sub.qty_available > 0 ? 'bg-success' : 'bg-danger'}">
                                            <t t-esc="sub.qty_available"/>
                                        </span>
                                    </td>
                                    <td class="text-end d-flex gap-2 justify-content-end">
                                        <button class="btn btn-primary btn-sm" t-on-click="() => this.onSelect(sub)" title="Replace Current Line">
                                            Replace
                                        </button>
                                        <button class="btn btn-outline-primary btn-sm" t-on-click="() => this.onAdd(sub)" title="Add as New Line">
                                            Add to Order
                                        </button>
                                    </td>
                                </tr>
                            </t>
                            <tr t-if="filteredSubstitutes.length === 0">
                                <td colspan="4" class="text-center py-4 text-muted">
                                    No substitutes match your search.
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <t t-slot="footer">
                <button class="btn btn-secondary" t-on-click="props.close">Close</button>
            </t>
        </Dialog>
    </t>
</templates>
