<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Combined Form View -->
    <record id="product_template_form_view_pharmacy" model="ir.ui.view">
        <field name="name">product.template.form.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- General Information: Code, Registration No., Margin -->
            <xpath expr="//group[@name='group_general']" position="inside">
                <field name="code" string="Code"/>
                <field name="registration_number" string="Registration No."/>
                <label for="pharmacy_margin_input" string="Pharmacy Margin (%)"/>
                <div class="o_row">
                    <field name="pharmacy_margin_input" class="oe_inline"/>
                    <span class="text-muted" invisible="not pharmacy_margin">(Actual: <field name="pharmacy_margin" class="oe_inline"/>%)</span>
                </div>
            </xpath>
            <!-- Tab Refinement -->
            <xpath expr="//sheet/notebook" position="inside">
                <!-- Pharmacy Management Tab -->
                <page name="pharmacy_management" string="Pharmacy Management">
                    <group>
                        <group name="group_pharmacy_basic" string="Drug Identification">
                            <field name="atc_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                            <field name="form_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                            <field name="strength_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                            <field name="presentation_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                            <field name="stratum_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                        </group>
                    </group>
                    <group string="Ingredients &amp; Composition">
                        <field name="composition"
                               widget="many2many_tags"
                               options="{'color_field': 'color'}"
                               nolabel="1"
                               placeholder="Add ingredients for POS substitution..."/>
                    </group>
                </page>

                <!-- Box Management Tab -->
                <page name="box_management" string="Box Management">
                    <group>
                        <group name="group_box_config" string="Configuration">
                            <field name="is_box_product"/>
                            <field name="envelope_child_id" invisible="not is_box_product"/>
                            <field name="envelopes_per_box" invisible="not is_box_product"/>
                            <field name="parent_box_id" readonly="1" invisible="not parent_box_id"/>
                        </group>
                        <group name="group_box_status" string="Inventory Status">
                             <field name="envelope_qty" readonly="1" string="Available Loose Envelopes"/>
                             <field name="qty_available" string="Physical Inventory"/>
                        </group>
                    </group>
                    <group string="Operations">
                         <div class="alert alert-info" role="status" invisible="not is_box_product">
                            Opening a box will deduct 1 from this product's stock (Physical Inventory) and add <field name="envelopes_per_box" class="oe_inline"/> to the child product.
                         </div>
                         <button name="action_open_new_box" string="Open New Box" type="object" 
                                 class="btn-primary" icon="fa-archive"
                                 invisible="not is_box_product"/>
                    </group>
                </page>

                <!-- MOH / Regulatory Tab -->
                <page string="MOH / Regulatory" name="pharmacy_moh_regulatory">
                  <group>
                    <group string="Regulatory Partners">
                      <field name="agent_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                      <field name="responsible_party_id" options="{'no_create': False, 'no_quick_create': False, 'no_create_edit': False}"/>
                    </group>
                  </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Combined Tree View -->
    <record id="product_template_tree_view_pharmacy" model="ir.ui.view">
        <field name="name">product.template.tree.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="code" string="Code" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_box_product" optional="show"/>
                <field name="form_id" optional="hide"/>
                <field name="strength_id" optional="hide"/>
                <field name="presentation_id" optional="show"/>
                <field name="atc_id" optional="show"/>
                <field name="stratum_id" optional="show"/>
                <field name="composition_text" optional="show"/>
                <field name="qty_available" string="Physical Inventory" optional="show" decoration-danger="qty_available &lt; 0"/>
            </xpath>
        </field>
    </record>

    <!-- Search View moved to views/product_search_views.xml for consolidation -->

    <!-- POS Form View Inheritance removed for Odoo 20 compatibility: no custom fields added to avoid parseFieldNode errors -->

</odoo>
