<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_pharmacy_simple" model="ir.ui.view">
        <field name="name">product.template.form.pharmacy.simple</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page name="pharmacy_management" string="Pharmacy Management">
                    <group>
                        <field name="is_box_product"/>
                        <field name="envelope_child_id"/>
                        <field name="envelopes_per_box" invisible="not is_box_product"/>
                        <field name="parent_box_id" readonly="1"/>
                        <field name="envelope_price"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
