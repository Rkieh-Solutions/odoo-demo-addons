<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- ATC Tree View (Hierarchy representation) -->
    <record id="view_pharmacy_atc_tree" model="ir.ui.view">
        <field name="name">pharmacy.atc.tree</field>
        <field name="model">pharmacy.atc</field>
        <field name="arch" type="xml">
            <tree sample="1">
                <field name="name"/>
                <field name="description"/>
                <field name="level" optional="show"/>
                <field name="parent_id" optional="hide"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- ATC Form View -->
    <record id="view_pharmacy_atc_form" model="ir.ui.view">
        <field name="name">pharmacy.atc.form</field>
        <field name="model">pharmacy.atc</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="ATC Code"/>
                        <h1>
                            <field name="name" placeholder="e.g. N02BE01"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="description" placeholder="Therapeutic group description..."/>
                            <field name="parent_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="level"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Child ATC Codes" name="children">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="description"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ATC Search View -->
    <record id="view_pharmacy_atc_search" model="ir.ui.view">
        <field name="name">pharmacy.atc.search</field>
        <field name="model">pharmacy.atc</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="description"/>
            </search>
        </field>
    </record>

    <!-- ATC Action -->
    <record id="action_pharmacy_atc" model="ir.actions.act_window">
        <field name="name">ATC Codes</field>
        <field name="res_model">pharmacy.atc</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_level1': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new ATC classification code.
            </p>
            <p>
                The ATC system is used for the classification of active ingredients of drugs 
                according to the organ or system on which they act and their therapeutic, 
                pharmacological and chemical properties.
            </p>
        </field>
    </record>

</odoo>
