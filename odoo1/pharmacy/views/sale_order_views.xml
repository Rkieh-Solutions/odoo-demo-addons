<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_pharmacy" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.pharmacy</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="after">
                <field name="is_envelope" optional="show"/>
                <field name="need_open_box" invisible="1"/>
                <button name="action_open_box" type="object" icon="fa-archive" 
                        title="Open Box" invisible="not need_open_box"
                        class="text-warning"/>
            </xpath>
        </field>
    </record>
</odoo>
