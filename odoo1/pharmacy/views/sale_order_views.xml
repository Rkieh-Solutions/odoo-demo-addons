<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_inherit_pharmacy" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.pharmacy</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                <field name="is_envelope" string="Envelope" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='order_line']/form//field[@name='product_id']" position="after">
                <field name="is_envelope"/>
            </xpath>
        </field>
    </record>
</odoo>
