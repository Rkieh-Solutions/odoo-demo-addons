<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- 
        URGENT NUCLEAR CLEANUP: 
        This file aggressively deletes all potential conflicting views from the database 
        before Odoo tries to load the new ones in this version (20.0.1.0.2).
    -->
    
    <!-- Delete old modules' views by search string in name (very aggressive) -->
    <delete model="ir.ui.view" search="[('name', 'ilike', 'pharmacy'), ('model', 'in', ['product.template', 'sale.order'])]"/>
    <delete model="ir.ui.view" search="[('name', 'ilike', 'inherit.composition')]"/>
    <delete model="ir.ui.view" search="[('name', 'ilike', 'product.template.search.pharmacy')]"/>
    <delete model="ir.ui.view" search="[('name', 'ilike', 'view_order_form_inherit_pharmacy')]"/>
    <delete model="ir.ui.view" search="[('name', 'ilike', 'sale.order.form.inherit.pharmacy')]"/>

    <!-- Delete potential model data records from both possible module names -->
    <delete model="ir.model.data" search="[('module', 'in', ['pharmacy', 'phar']), ('model', '=', 'ir.ui.view')]"/>

</odoo>
