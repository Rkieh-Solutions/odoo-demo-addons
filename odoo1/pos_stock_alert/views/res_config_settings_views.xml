<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_stock_alert" model="ir.ui.view">
        <field name="name">res.config.settings.form.inherit.stock.alert</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='production_lot_info']" position="after">
                <block title="POS Stock Alerts" id="pos_stock_alert_section">
                    <setting string="Global Warning Threshold" help="Set a default threshold for low stock warnings in POS.">
                        <field name="x_global_stock_warn_threshold"/>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
