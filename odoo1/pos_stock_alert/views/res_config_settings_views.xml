<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_pos_stock_alert" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.pos.stock.alert</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="point_of_sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@id='pos_inventory_section']" position="inside">
                <setting id="global_stock_warn_setting" string="Global Stock Warning Threshold" help="Default warning threshold for all products.">
                    <field name="x_global_stock_warn_threshold"/>
                </setting>
            </xpath>
        </field>
    </record>
</odoo>
