<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_inherit_pos_stock_alert" model="ir.ui.view">
        <field name="name">product.template.form.inherit.pos.stock.alert</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Stock Alerts" name="stock_alerts">
                    <group>
                        <field name="x_qty_to_warn" string="POS Warning Threshold"/>
                        <field name="x_no_stock_warning"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
