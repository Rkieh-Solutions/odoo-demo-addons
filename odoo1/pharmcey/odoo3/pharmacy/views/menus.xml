<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pharmacy Root as Dashboard App -->
    <menuitem id="menu_pharmacy_root" 
              name="Pharmacy" 
              web_icon="pharmacy,static/description/icon.png"
              sequence="1"/>

    <!-- Integrated Menus -->
    
    <!-- 1. Under Inventory / Operations -->
    <menuitem id="menu_pharmacy_stock_ops" 
              name="Pharmacy Operations" 
              parent="stock.menu_stock_warehouse_mgmt" 
              action="product.product_template_action_all"
              sequence="50"/>

    <!-- 2. Under POS / Products -->
    <menuitem id="menu_pharmacy_pos_products"
              name="Pharmacy Products"
              parent="point_of_sale.menu_pos_products"
              action="product.product_template_action_all"
              sequence="20"/>

    <!-- Configuration Section -->
    <menuitem id="menu_pharmacy_config" 
              name="Pharmacy" 
              parent="stock.menu_stock_config_settings" 
              sequence="60"/>

    <menuitem id="menu_pharmacy_config_forms"
              name="Forms"
              parent="menu_pharmacy_config"
              action="action_pharmacy_form"
              sequence="10"/>

    <menuitem id="menu_pharmacy_config_ingredients"
              name="Ingredients"
              parent="menu_pharmacy_config"
              action="action_pharmacy_composition"
              sequence="15"/>

    <menuitem id="menu_pharmacy_config_presentations"
              name="Presentations"
              parent="menu_pharmacy_config"
              action="action_pharmacy_presentation"
              sequence="20"/>

    <menuitem id="menu_pharmacy_config_strengths"
              name="Strengths"
              parent="menu_pharmacy_config"
              action="action_pharmacy_strength"
              sequence="30"/>

    <menuitem id="menu_pharmacy_config_atc"
              name="ATC Codes"
              parent="menu_pharmacy_config"
              action="action_pharmacy_atc"
              sequence="40"/>

    <menuitem id="menu_pharmacy_config_stratum"
              name="Strata"
              parent="menu_pharmacy_config"
              action="action_pharmacy_stratum"
              sequence="50"/>

    <menuitem id="menu_pharmacy_config_agents"
              name="Agents"
              parent="menu_pharmacy_config"
              action="action_pharmacy_agents"
              sequence="60"/>
</odoo>
