<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Composition Search View -->
    <record id="view_pharmacy_composition_search" model="ir.ui.view">
        <field name="name">pharmacy.composition.search</field>
        <field name="model">pharmacy.composition</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Composition Tree View -->
    <record id="view_pharmacy_composition_tree" model="ir.ui.view">
        <field name="name">pharmacy.composition.tree</field>
        <field name="model">pharmacy.composition</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="color" widget="color_picker"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Composition Action -->
    <record id="action_pharmacy_composition" model="ir.actions.act_window">
        <field name="name">Ingredients</field>
        <field name="res_model">pharmacy.composition</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new active ingredient.
            </p>
        </field>
    </record>

</odoo>
