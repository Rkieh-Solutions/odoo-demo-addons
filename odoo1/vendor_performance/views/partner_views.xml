<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_form_inherit_performance" model="ir.ui.view">
        <name>res.partner.form.inherit.performance</name>
        <model>res.partner</model>
        <inherit_id ref="base.view_partner_form"/>
        <arch type="xml">
            <xpath expr="//page[@name='internal_notes']" position="before">
                <page name="vendor_performance" string="Vendor Performance" attrs="{'invisible': [('supplier_rank', '=', 0)]}">
                    <group>
                        <group string="Quantity Metrics">
                            <field name="accepted_qty" readonly="1"/>
                            <field name="failed_qty" readonly="1"/>
                        </group>
                        <group string="Performance Rating">
                            <field name="damage_rate" widget="percentage"/>
                            <field name="vendor_rating" widget="priority" decoration-success="vendor_rating == 'excellent'" decoration-warning="vendor_rating == 'good'" decoration-danger="vendor_rating == 'poor'"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </arch>
    </record>
</odoo>
