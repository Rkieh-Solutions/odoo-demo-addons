<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Presentation Tree View -->
    <record id="view_pharmacy_presentation_tree" model="ir.ui.view">
        <field name="name">pharmacy.presentation.tree</field>
        <field name="model">pharmacy.presentation</field>
        <field name="arch" type="xml">
            <tree editable="bottom" sample="1">
                <field name="name"/>
                <field name="description"/>
                <field name="active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Presentation Form View -->
    <record id="view_pharmacy_presentation_form" model="ir.ui.view">
        <field name="name">pharmacy.presentation.form</field>
        <field name="model" >pharmacy.presentation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Presentation Name"/>
                        <h1>
                            <field name="name" placeholder="e.g. 10 Tablets per strip, 100ml Bottle..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Presentation Search View -->
    <record id="view_pharmacy_presentation_search" model="ir.ui.view">
        <field name="name">pharmacy.presentation.search</field>
        <field name="model">pharmacy.presentation</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Presentation Action -->
    <record id="action_pharmacy_presentation" model="ir.actions.act_window">
        <field name="name">Presentations</field>
        <field name="res_model">pharmacy.presentation</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Presentation classification.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_pharmacy_presentation"
              name="Presentations"
              parent="menu_pharmacy_config"
              action="action_pharmacy_presentation"
              sequence="40"/>
</odoo>
