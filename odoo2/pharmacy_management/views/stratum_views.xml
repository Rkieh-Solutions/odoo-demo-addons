<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- Stratum Tree View -->
    <record id="view_pharmacy_stratum_tree" model="ir.ui.view">
        <field name="name">pharmacy.stratum.tree</field>
        <field name="model">pharmacy.stratum</field>
        <field name="arch" type="xml">
            <list editable="bottom" sample="1">
                <field name="name"/>
                <field name="description"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Stratum Form View -->
    <record id="view_pharmacy_stratum_form" model="ir.ui.view">
        <field name="name">pharmacy.stratum.form</field>
        <field name="model">pharmacy.stratum</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. Critical, Essential..."/>
                        </h1>
                    </div>
                    <group>
                        <field name="active" widget="boolean_toggle"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Stratum Search View -->
    <record id="view_pharmacy_stratum_search" model="ir.ui.view">
        <field name="name">pharmacy.stratum.search</field>
        <field name="model">pharmacy.stratum</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <filter string="Archived" name="inactive" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Stratum Action -->
    <record id="action_pharmacy_stratum" model="ir.actions.act_window">
        <field name="name">Stratum</field>
        <field name="res_model">pharmacy.stratum</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Stratum classification.
            </p>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_pharmacy_stratum"
              name="Stratum"
              parent="menu_pharmacy_config"
              action="action_pharmacy_stratum"
              sequence="20"/>
</odoo>
