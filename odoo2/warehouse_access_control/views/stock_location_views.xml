<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_location_form_map_inherit" model="ir.ui.view">
        <field name="name">stock.location.form.map.inherit</field>
        <field name="model">stock.location</field>
        <field name="inherit_id" ref="stock.view_location_form"/>
        <field name="arch" type="xml">
            <!-- Insert our map coordinate group after the 'usage' field which exists in all Odoo versions -->
            <xpath expr="//field[@name='usage']" position="after">
                <group string="Visual Map Position" name="group_map_position">
                    <field name="warehouse_map_id"/>
                    <label for="x_pos" string="Position on Map (X % , Y %)"/>
                    <div class="o_row">
                        <field name="x_pos" class="oe_inline"/> % ,&#160;
                        <field name="y_pos" class="oe_inline"/> %
                    </div>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
