<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sale_order_open_box_wizard_form" model="ir.ui.view">
        <field name="name">sale.order.open.box.wizard.form</field>
        <field name="model">sale.order.open.box.wizard</field>
        <field name="arch" type="xml">
            <form string="⚠️ Not Enough Loose Envelopes">
                <group>
                    <field name="message" widget="text" readonly="1" nolabel="1"/>
                </group>
                <footer>
                    <button name="action_open_boxes_and_confirm" string="Open Box &amp; Confirm Order"
                            type="object" class="btn-primary" data-hotkey="q"/>
                    <button name="action_cancel" string="Cancel" type="object" class="btn-secondary" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_sale_order_open_box_wizard" model="ir.actions.act_window">
        <field name="name">Open Box &amp; Confirm</field>
        <field name="res_model">sale.order.open.box.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
