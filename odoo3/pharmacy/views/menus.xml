<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Actions for App Views -->
    <record id="action_pharmacy_products" model="ir.actions.act_window">
        <field name="name">Pharmacy Products</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'search_default_filter_to_sell': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Manage your pharmaceutical inventory here.
            </p>
        </field>
    </record>

    <!-- Pharmacy Root as Dashboard App -->
    <menuitem id="menu_pharmacy_root" 
              name="Pharmacy" 
              web_icon="pharmacy,static/description/icon.png"
              action="action_pharmacy_products"
              sequence="1"/>

    <!-- Operations View -->
    <menuitem id="menu_pharmacy_operations"
              name="Operations"
              parent="menu_pharmacy_root"
              sequence="10"/>

    <menuitem id="menu_pharmacy_all_products"
              name="Products"
              parent="menu_pharmacy_operations"
              action="action_pharmacy_products"
              sequence="10"/>

    <!-- Configuration Section -->
    <menuitem id="menu_pharmacy_config" 
              name="Configuration" 
              parent="menu_pharmacy_root" 
              sequence="100"/>

    <menuitem id="menu_pharmacy_config_forms"
              name="Drug Forms"
              parent="menu_pharmacy_config"
              action="action_pharmacy_form"
              sequence="10"/>

    <menuitem id="menu_pharmacy_config_ingredients"
              name="Ingredients"
              parent="menu_pharmacy_config"
              action="action_pharmacy_composition"
              sequence="15"/>

    <menuitem id="menu_pharmacy_config_presentations"
              name="Presentations"
              parent="menu_pharmacy_config"
              action="action_pharmacy_presentation"
              sequence="20"/>

    <menuitem id="menu_pharmacy_config_strengths"
              name="Strengths"
              parent="menu_pharmacy_config"
              action="action_pharmacy_strength"
              sequence="30"/>

    <menuitem id="menu_pharmacy_config_atc"
              name="ATC Codes"
              parent="menu_pharmacy_config"
              action="action_pharmacy_atc"
              sequence="40"/>

    <menuitem id="menu_pharmacy_config_stratum"
              name="Strata"
              parent="menu_pharmacy_config"
              action="action_pharmacy_stratum"
              sequence="50"/>

    <menuitem id="menu_pharmacy_config_agents"
              name="Agents"
              parent="menu_pharmacy_config"
              action="action_pharmacy_agents"
              sequence="60"/>
</odoo>
