<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Pharmacy Root as Dashboard App -->
    <menuitem id="menu_pharmacy_root" 
              name="Pharmacy" 
              web_icon="pharmacy,static/description/icon.png"
              sequence="100"/>

    <!-- Integrated Menus -->
    
    <!-- 1. Under Inventory / Operations -->
    <menuitem id="menu_pharmacy_stock_ops" 
              name="Pharmacy Operations" 
              parent="stock.menu_stock_warehouse_mgmt" 
              action="product.product_template_action_all"
              sequence="50"/>

    <!-- 2. Under POS / Products -->
    <menuitem id="menu_pharmacy_pos_products"
              name="Pharmacy Products"
              parent="point_of_sale.menu_pos_products"
              action="product.product_template_action_all"
              sequence="20"/>

    <!-- Configuration Section -->
    <menuitem id="menu_pharmacy_config" 
              name="Pharmacy" 
              parent="stock.menu_stock_config_settings" 
              sequence="60"/>
</odoo>
