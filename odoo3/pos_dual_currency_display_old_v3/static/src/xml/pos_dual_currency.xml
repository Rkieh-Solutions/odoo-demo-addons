<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.ProductCard" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('product-name')]" position="after">
            <t t-if="secondaryPrice">
                <div class="o_pos_secondary_currency text-muted small">
                    <t t-esc="secondaryPrice"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.Orderline" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('price')]" position="after">
            <t t-if="secondaryLinePrice">
                <div class="o_pos_secondary_currency text-muted small">
                    <t t-esc="secondaryLinePrice"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.OrderDisplay" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('total')]" position="after">
            <t t-if="secondaryTotal">
                <div class="o_pos_secondary_currency text-muted small ms-2">
                    <t t-esc="secondaryTotal"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.PaymentScreenStatus" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('amount')]" position="after">
            <t t-if="secondaryStatusAmount">
                <div class="o_pos_secondary_currency text-muted small">
                    <t t-esc="secondaryStatusAmount"/>
                </div>
            </t>
        </xpath>
    </t>

    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension">
        <xpath expr="//*[hasclass('receipt-total')]" position="after">
            <t t-if="secondaryReceiptTotal">
                <div class="pos-receipt-amount d-flex w-100 text-muted" style="font-size:90%">
                    <span class="label-total" style="flex: 1;"/>
                    <span t-esc="secondaryReceiptTotal" class="pos-receipt-right-align font-monospace"/>
                </div>
            </t>
        </xpath>
    </t>

</templates>
