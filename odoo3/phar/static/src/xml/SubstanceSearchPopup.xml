<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="phar.SubstanceSearchPopup">
        <Dialog title="props.title" footer="false" size="'md'">
            <div class="substance-search-popup d-flex flex-column gap-3">
                <div class="search-box input-group">
                    <span class="input-group-text"><i class="fa fa-search text-muted"/></span>
                    <input type="text" class="form-control" placeholder="Search Substance or Product..." 
                           t-on-input="onSearchInput" t-ref="search-input"/>
                </div>
                
                <div t-if="state.isShowingAlternatives and state.originalProductName" class="alert alert-info py-2 mb-0 shadow-sm border-0 d-flex align-items-center">
                    <i class="fa fa-refresh me-2 text-primary"/>
                    <span>Alternatives for: <strong t-esc="state.originalProductName"/></span>
                </div>

                <div class="product-list overflow-auto pe-1" style="max-height: 450px; min-height: 100px;">
                    <t t-if="state.products.length == 0 and (state.searchTerm or state.isShowingAlternatives)">
                        <div class="text-center p-4 text-muted bg-light rounded">
                            <i class="fa fa-info-circle mb-2 d-block fs-4"/>
                            No alternatives or products found. Try searching by name.
                        </div>
                    </t>
                    <div t-foreach="state.products" t-as="item" t-key="item.product.id"
                         class="product-item d-flex align-items-center justify-content-between p-3 border-bottom shadow-sm rounded mb-2 bg-white hover-bg-light transition-all">
                        <div class="d-flex flex-column overflow-hidden me-2 flex-grow-1">
                            <strong class="text-truncate fs-6" t-esc="item.product.display_name"/>
                            <small class="text-muted text-truncate" t-esc="item.product.composition_text or 'No substance data'"/>
                        </div>
                        <div class="d-flex align-items-center gap-3 flex-shrink-0">
                            <span class="badge bg-soft-info text-info border border-info px-2 py-1" t-esc="item.formatted_price"/>
                            <div class="btn-group shadow-sm">
                                <button t-if="item.product.qty_available &lt;= 0 and (item.product.is_box_product or item.product.parent_box_id)" 
                                        class="btn btn-outline-info btn-sm"
                                        t-on-click="() => this.onOpenBox(item.product)"
                                        title="Open a new box for this product">
                                    <i class="fa fa-archive"/>
                                </button>
                                <button t-if="state.selectedLine" class="btn btn-outline-warning btn-sm border-end-0 px-3" 
                                        t-on-click="() => this.replaceLine(item.product)" 
                                        title="Replace selected item">
                                    <i class="fa fa-exchange me-1"/> Replace
                                </button>
                                <button class="btn btn-primary btn-sm px-3" 
                                        t-on-click="() => this.addToOrder(item.product)" 
                                        title="Add to order">
                                    <i class="fa fa-plus me-1"/> Add
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-4 pt-3 border-top">
                <button class="btn btn-secondary px-4" t-on-click="props.close">Close</button>
            </div>
        </Dialog>
    </t>
</templates>
