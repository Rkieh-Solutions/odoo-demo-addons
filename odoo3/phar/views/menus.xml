<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Move Pharmacy Root under Inventory (removes dashboard icon) -->
    <menuitem id="menu_pharmacy_inventory" 
              name="Pharmacy" 
              parent="stock.menu_stock_root" 
              sequence="100"/>

    <menuitem id="menu_pharmacy_products" 
              name="Products" 
              parent="menu_pharmacy_inventory" 
              action="product.product_template_action_all" 
              sequence="10"/>

    <!-- Configuration Section (in standard Inventory / Configuration) -->
    <menuitem id="menu_pharmacy_config" 
              name="Pharmacy" 
              parent="stock.menu_stock_config_settings" 
              sequence="60"/>
</odoo>
