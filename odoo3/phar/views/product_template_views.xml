<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Combined Form View -->
    <record id="product_template_form_view_pharmacy" model="ir.ui.view">
        <field name="name">product.template.form.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <!-- General Information: Code, ATC, Registration No., Margin (from extension) -->
            <xpath expr="//group[@name='group_general']" position="inside">
                <field name="code" string="Code"/>
                <field name="atc_id" options="{'no_create': True, 'no_open': True}"/>
                <field name="registration_number" string="Registration No."/>
                <label for="pharmacy_margin_input" string="Margin (%)"/>
                <div class="o_row">
                    <field name="pharmacy_margin_input" class="oe_inline"/>
                </div>
                <field name="is_box_product" invisible="1"/> <!-- Keep for logic -->
            </xpath>

            <xpath expr="//notebook" position="inside">
                <!-- Unified Pharmacy Tab -->
                <page name="pharmacy" string="Pharmacy">
                    <group>
                        <group name="group_pharmacy_config" string="Relationship Configuration">
                            <field name="is_box_product"/>
                            <field name="envelope_child_id" invisible="not is_box_product" required="is_box_product"/>
                            <field name="envelopes_per_box" invisible="not is_box_product" required="is_box_product"/>
                        </group>
                        <group name="group_pharmacy_actions" string="Actions" 
                               invisible="not is_box_product and not parent_box_id">
                             <field name="envelope_qty" readonly="1" string="Available Envelopes"/>
                             <button name="action_open_new_box" string="Open New Box" type="object" 
                                     class="oe_highlight" invisible="not is_box_product and not parent_box_id"/>
                        </group>
                        <group name="group_child_config" string="Child Relationship" invisible="not parent_box_id">
                            <field name="parent_box_id" readonly="1"/>
                        </group>
                    </group>
                    
                    <group string="Pharmaceutical Properties" name="drug_properties">
                        <group>
                            <field name="form_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="strength_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="presentation_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="stratum_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                    </group>

                    <group string="Ingredients &amp; Composition">
                        <field name="composition"
                               widget="many2many_tags"
                               options="{'color_field': 'color', 'no_create_edit': True}"
                               nolabel="1"
                               placeholder="Add ingredients..."/>
                    </group>

                    <group string="MOH / Regulatory">
                        <group>
                            <field name="registration_number"/>
                            <field name="atc_id" options="{'no_create': True, 'no_open': True}"/>
                        </group>
                        <group>
                            <field name="agent_id"/>
                            <field name="responsible_party_id"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Combined Tree View -->
    <record id="product_template_tree_view_pharmacy" model="ir.ui.view">
        <field name="name">product.template.tree.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="before">
                <field name="code" string="Code" optional="show"/>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_box_product" optional="show"/>
                <field name="form_id" optional="hide"/>
                <field name="strength_id" optional="hide"/>
                <field name="presentation_id" optional="show"/>
                <field name="atc_id" optional="show"/>
                <field name="stratum_id" optional="show"/>
                <field name="composition_text" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Combined Search View -->
    <record id="product_template_search_view_pharmacy" model="ir.ui.view">
        <field name="name">product.template.search.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_search_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="code"/>
                <filter string="Box Products" name="box_products" domain="[('is_box_product', '=', True)]"/>
            </xpath>
        </field>
    </record>

    <!-- POS Form View Inheritance -->
    <record id="product_template_view_form_normalized_pos_pharmacy" model="ir.ui.view">
        <field name="name">product.template.view.form.normalized.pharmacy</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="point_of_sale.product_template_view_form_normalized_pos"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pos_categ_ids']" position="after">
                <field name="is_box_product"/>
                <field name="envelope_child_id" invisible="not is_box_product"/>
                <field name="parent_box_id" invisible="not parent_box_id" readonly="1"/>
                <field name="composition" widget="many2many_tags" string="Ingredients &amp; Composition" placeholder="Add ingredients for substitution..."/>
            </xpath>
        </field>
    </record>

</odoo>
