<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">
    <t t-name="pharmacy.SubstanceSearchPopup">
        <Dialog title="props.title" footer="false" size="'md'">
            <div class="substance-search-popup d-flex flex-column gap-3">
                <div class="search-box input-group">
                    <span class="input-group-text"><i class="fa fa-search"/></span>
                    <input type="text" class="form-control" placeholder="Search Substance or Product..." 
                           t-on-input="onSearchInput" t-ref="search-input"/>
                </div>
                
                <div t-if="state.isShowingAlternatives and state.originalProductName" class="alert alert-info py-2 mb-0">
                    <i class="fa fa-refresh me-2"/>Alternatives for: <strong t-esc="state.originalProductName"/>
                </div>

                <div class="product-list overflow-auto pe-2" style="max-height: 400px; min-height: 100px;">
                    <t t-if="state.products.length == 0 and (state.searchTerm or state.isShowingAlternatives)">
                        <div class="text-center p-3 text-muted">No alternatives found. Try searching by name.</div>
                    </t>
                    <div t-foreach="state.products" t-as="item" t-key="item.product.id"
                         class="product-item d-flex align-items-center justify-content-between p-2 border-bottom shadow-sm rounded mb-2 bg-light">
                        <div class="d-flex flex-column overflow-hidden me-2">
                            <strong class="text-truncate" t-esc="item.product.display_name"/>
                            <small class="text-muted text-truncate" t-esc="item.product.composition_text or 'No substance data'"/>
                        </div>
                        <div class="d-flex align-items-center gap-2 flex-shrink-0">
                            <span class="badge bg-info text-dark" t-esc="item.formatted_price"/>
                            <div class="btn-group">
                                <button t-if="state.selectedLine" class="btn btn-warning btn-sm p-2" 
                                        t-on-click="() => this.replaceLine(item.product)" 
                                        title="Replace selected item" 
                                        style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa fa-exchange"/>
                                </button>
                                <button class="btn btn-primary btn-sm p-2" 
                                        t-on-click="() => this.addToOrder(item.product)" 
                                        title="Add to order" 
                                        style="width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fa fa-plus"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end mt-3 pt-2 border-top">
                <button class="btn btn-secondary" t-on-click="props.close">Close</button>
            </div>
        </Dialog>
    </t>
</templates>
